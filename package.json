{
  "name": "lazy_mobile_mcp",
  "version": "1.0.3",
  "description": "Local MCP server for Android/iOS device automation and performance telemetry (ADB, simctl, devicectl, WDA)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lazy-mobile-mcp": "bin/lazy-mobile-mcp.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "mobile",
    "android",
    "ios",
    "mobile-automation",
    "adb",
    "webdriveragent",
    "simctl",
    "performance-telemetry",
    "model-context-protocol"
  ],
  "author": "leaf76",
  "license": "MIT",
  "homepage": "https://github.com/leaf76/lazy_mobile_mcp#readme",
  "bugs": {
    "url": "https://github.com/leaf76/lazy_mobile_mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leaf76/lazy_mobile_mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.22.0",
    "better-sqlite3": "^12.4.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "3.2.4"
  }
}
